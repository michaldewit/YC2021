# Copy this file to .env and fill in EVERY value before starting.
# .env is listed in .gitignore and must never be committed.

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ── JWT ──────────────────────────────────────────��──────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=approvals
POSTGRES_USER=approvaluser
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=approvaluser
RABBITMQ_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── MinIO ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY
