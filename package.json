{
  "name": "document-approval-system",
  "version": "1.0.0",
  "description": "CQRS-based document approval system with 4-eye principle, event sourcing, and reference integrity",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "migrate": "node src/db/migrate.js",
    "e2e": "node scripts/e2e-test.js",
    "agent:references": "node src/agents/referenceConsistencyAgent.js",
    "agent:approvals": "node src/agents/approvalIntegrityAgent.js",
    "agent:projections": "node src/agents/projectionSyncAgent.js",
    "agent:replay": "node src/agents/eventReplayAgent.js",
    "agent:orphans": "node src/agents/orphanDetectionAgent.js"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "ajv": "^8.12.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "md5": "^2.3.0",
    "minio": "^7.1.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js"]
  }
}
